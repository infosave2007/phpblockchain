# Git
.git
.gitignore

# Documentation
*.md
docs/

# Logs
logs/
*.log

# Cache
.phpunit.cache/
storage/cache/
storage/logs/

# Dependencies
node_modules/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment & secrets (provided via compose `environment:` / mounted at runtime)
.env
.env.local
.env.production

# Heavy / sensitive artifacts that must never enter the image
*.sql
*.sql.gz
*.gz
*.jpeg
*.jpg

# Dev scratch / test scripts in repo root
test_*.php
*_REPORT.md
*_FIX*.md
*_SUMMARY.md

# Temporary files
tmp/
temp/

# Release artifacts
release-*.zip
RELEASE_META.json

# Blockchain runtime data (mounted via volumes instead)
storage/blockchain/
storage/state/
storage/trustwallet/
storage/test/

# Local composer lock can optionally be excluded for faster iterative dev builds (comment out if deterministic builds needed)
composer.lock
